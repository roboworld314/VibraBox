---
// ProblemStatement.astro — Section 2: Problem Statement + Image Showcase merged

const imageGroups = [
  {
    description: "Critical example of failure and near miss.",
    images: [
      { 
        src: "https://drive.google.com/file/d/1niyuelhmT75kiylbe4b-OKTOX10nwyKl/preview", 
        alt: "Conventional storage video", 
        isVideo: true 
      }, 
      { 
        src: "https://drive.google.com/thumbnail?id=1cCOkD-07gkVU_4yxMg31fcoXqf5gX9MT&sz=w1000", 
        alt: "Adaptive storage", 
        isVideo: false 
      },
    ],
  },
  {
    description: "Why existing system fails!",
    images: [
      { 
        src: "https://drive.google.com/file/d/1d0NzHbr9tLY3J6kul0ASwKZL9BZiMAeu/preview", 
        alt: "Conventional storage video", 
        isVideo: true 
      }, 
      { 
        src: "https://drive.google.com/thumbnail?id=16Yvv_30e39Ls8XdcL4X_U8xKTXmARlnF&sz=w1000", 
        alt: "Adaptive storage", 
        isVideo: false 
      },
    ],
  },
];
---

<!-- Section 1: Problem Statement -->
<section id="problem-statement" class="content-section">
  <div class="section-container">
    <h2 class="section-heading reveal">System-Level Bottlenecks in Perception-Faithful Replay</h2>

    <div class="prose reveal">
      <p>
      Mobile robots operate in dynamic, uncertain environments where rare failures and near-misses are inevitable. Yet, reconstructing what truly happened remains a fundamental challenge. Capturing reliable, decision-critical evidence is therefore essential for accurate reconstruction and analysis.
      </p>

      <div class="problem-highlights">
        <p>Existing approaches are limited in three key ways:</p>
        
        <div class="highlight-box">
          <div class="highlight-item">
            <span class="highlight-number">
              <span class="emoji-icon">⚠️</span>
            </span>
            <div class="highlight-content">
              <h4>Incomplete Evidence</h4>
              <p>External sensors miss internal autonomy states and decisions.</p>
            </div>
          </div>

          <div class="highlight-item">
            <span class="highlight-number">
              <span class="emoji-icon">💾</span>
            </span>
            <div class="highlight-content">
              <h4>Infeasible Recording</h4>
              <p>Full-resolution logging exceeds onboard compute and storage budgets.</p>
            </div>
          </div>

          <div class="highlight-item">
            <span class="highlight-number">
              <span class="emoji-icon">⚡</span>
            </span>
            <div class="highlight-content">
              <h4>Distorted Replay</h4>
              <p>Vibration-induced artifacts corrupt sensor data, causing replay to diverge from real behavior.</p>
            </div>
          </div>
        </div>
      </div>

      <p class="conclusion">
        These limitations make failure analysis unreliable and hinder continuous system improvement.
      </p>
    </div>
  </div>
</section>

<!-- Section 2: Image Showcase -->
<section id="image-showcase" class="content-section">
  <div class="section-container">
    <h2 class="section-heading reveal">Visual Evidence</h2>

    <div class="image-groups">
      {imageGroups.map((group, index) => (
        <div class="image-group reveal" style={`transition-delay: ${index * 0.1}s`}>
          <p class="group-description">{group.description}</p>
          <div class="image-pair">
            {group.images.map((media, mediaIndex) => (
              <div class="image-card card" key={mediaIndex}>
                {media.isVideo ? (
                  <div class="video-wrapper">
                    <iframe 
                      src={media.src} 
                      allow="autoplay" 
                      loading="lazy"
                      title={media.alt}>
                    </iframe>
                  </div>
                ) : (
                  <img src={media.src} alt={media.alt} loading="lazy" />
                )}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Section 3: Research Questions -->
<section id="research-questions" class="content-section">
  <div class="section-container">
    <h2 class="section-heading reveal">Research Questions</h2>

    <div class="prose reveal">
      <p>
        We propose <strong>VibraBox</strong>, a vibration-aware robot Black Box that enables efficient yet perception-faithful 
        recording under real-world disturbances. It is guided by three system-level research questions:
      </p>

      <div class="research-questions-box">
        <div class="question-item">
          <div class="question-badge">
            <span class="question-number">1</span>
          </div>
          <div class="question-content">
            <p>
              <strong>How to record</strong> continuously within bounded resources while preserving pre/during/post-event context?
            </p>
          </div>
        </div>

        <div class="question-item">
          <div class="question-badge">
            <span class="question-number">2</span>
          </div>
          <div class="question-content">
            <p>
              <strong>How to remove</strong> temporal and spatial redundancy without sacrificing downstream replay fidelity for 
              perception and localization?
            </p>
          </div>
        </div>

        <div class="question-item">
          <div class="question-badge">
            <span class="question-number">3</span>
          </div>
          <div class="question-content">
            <p>
              <strong>How to adapt</strong> to vibration-induced corruption so replay remains consistent with online behavior?
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ========== SECTION CONTAINER (MATCHES HERO.ASTRO) ========== */

  .content-section {
    padding: 4rem 2rem 3rem;
    width: 100%;
    box-sizing: border-box;
  }

  .section-container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    padding: 0 2rem;
    box-sizing: border-box;
  }

  /* ========== PROBLEM STATEMENT STYLES ========== */
  
  .section-heading {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 400;
    color: var(--color-primary);
    margin: 0 0 1.5rem 0;
    position: relative;
    padding-bottom: 0.75rem;
    word-break: break-word;
    letter-spacing: -0.015em;
    line-height: 1.2;
  }

  .section-heading::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 48px;
    height: 3px;
    background: var(--color-accent);
    border-radius: 2px;
  }

  .prose {
    max-width: 100%;
  }

  .prose p {
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text);
    margin-bottom: 1.25rem;
    word-break: break-word;
  }

  .prose p:last-child {
    margin-bottom: 0;
  }

  /* Problem Highlights Section */
  .problem-highlights {
    margin: 2rem 0 1.5rem 0;
  }

  .problem-highlights > p {
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
    font-size: 1rem;
  }

  .highlight-box {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.25rem;
    margin: 1.5rem 0;
  }

  .highlight-item {
    display: flex;
    gap: 1rem;
    padding: 1.25rem;
    background: linear-gradient(135deg, rgba(192, 94, 60, 0.05) 0%, rgba(27, 42, 74, 0.03) 100%);
    border-left: 4px solid var(--color-accent);
    border-radius: 10px;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .highlight-item::before {
    content: '';
    position: absolute;
    top: 0;
    right: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
    transition: right 0.5s ease;
  }

  .highlight-item:hover {
    background: linear-gradient(135deg, rgba(192, 94, 60, 0.08) 0%, rgba(27, 42, 74, 0.05) 100%);
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(27, 42, 74, 0.1);
  }

  .highlight-item:hover::before {
    right: 100%;
  }

  .highlight-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--color-accent);
    color: white;
    border-radius: 50%;
    font-weight: 700;
    font-size: 1.2rem;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .emoji-icon {
    font-size: 1.4rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    animation: float 3s ease-in-out infinite;
    transform-origin: center;
  }

  .highlight-item:nth-child(1) .emoji-icon {
    animation: float 3s ease-in-out infinite;
  }

  .highlight-item:nth-child(2) .emoji-icon {
    animation: pulse 2s ease-in-out infinite;
  }

  .highlight-item:nth-child(3) .emoji-icon {
    animation: vibrate 0.5s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-8px);
    }
  }

  @keyframes pulse {
    0%, 100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.15);
    }
  }

  @keyframes vibrate {
    0%, 100% {
      transform: translateX(0px);
    }
    25% {
      transform: translateX(-3px);
    }
    75% {
      transform: translateX(3px);
    }
  }

  .highlight-content h4 {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-primary);
    margin: 0 0 0.5rem 0;
    letter-spacing: -0.01em;
  }

  .highlight-content p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0;
  }

  .conclusion {
    margin-top: 1.75rem;
    padding: 1.25rem;
    background: linear-gradient(135deg, rgba(192, 94, 60, 0.05) 0%, rgba(27, 42, 74, 0.04) 100%);
    border-radius: 10px;
    border-left: 4px solid var(--color-primary);
    font-weight: 500;
    color: var(--color-primary);
    font-size: 1rem;
  }

  /* ========== IMAGE SHOWCASE STYLES ========== */

  .image-groups {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    margin-top: 1.5rem;
  }

  .image-group {
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--color-border-light);
  }

  .image-group:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .group-description {
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.7;
    color: var(--color-primary);
    margin: 0 0 1.5rem 0;
    max-width: 100%;
  }

  .image-pair {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .image-card {
    border-radius: 16px;
    overflow: hidden;
    background: #f5f5f5;
    aspect-ratio: 16 / 9;
    position: relative;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
    border: 1px solid var(--color-border-light);
  }

  .image-card:hover {
    box-shadow: 0 12px 32px rgba(27, 42, 74, 0.15);
    transform: translateY(-6px);
    border-color: var(--color-accent);
  }

  .video-wrapper {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #1a1a1a;
  }

  .video-wrapper iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  .image-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .image-card:hover img {
    transform: scale(1.05);
  }

  /* ========== RESEARCH QUESTIONS STYLES ========== */

  .research-questions-box {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.75rem;
    margin: 2.5rem 0 0 0;
  }

  .question-item {
    display: flex;
    gap: 1.5rem;
    padding: 1.75rem;
    background: linear-gradient(135deg, rgba(192, 94, 60, 0.03) 0%, rgba(27, 42, 74, 0.02) 100%);
    border: 2px solid var(--color-border-light);
    border-radius: 14px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    align-items: flex-start;
  }

  .question-item:hover {
    border-color: var(--color-accent);
    background: linear-gradient(135deg, rgba(192, 94, 60, 0.06) 0%, rgba(27, 42, 74, 0.04) 100%);
    box-shadow: 0 8px 24px rgba(192, 94, 60, 0.12);
    transform: translateY(-4px);
  }

  .question-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 60px;
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, var(--color-accent) 0%, #c0523c 100%);
    color: white;
    border-radius: 50%;
    flex-shrink: 0;
    box-shadow: 0 4px 12px rgba(192, 94, 60, 0.3);
    transition: all 0.3s ease;
  }

  .question-item:hover .question-badge {
    transform: scale(1.1);
    box-shadow: 0 6px 20px rgba(192, 94, 60, 0.4);
  }

  .question-number {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.8rem;
    line-height: 1;
    margin: 0;
    padding: 0;
  }

  .question-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .question-content p {
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-text);
    margin: 0;
  }

  .question-content strong {
    color: var(--color-accent);
    font-weight: 600;
  }

  /* ========== RESPONSIVE STYLES ========== */

  /* Tablet (1024px and below) */
  @media (max-width: 1024px) {
    .content-section {
      padding: 3.5rem 1.5rem 3rem;
    }

    .section-container {
      padding: 0 1.5rem;
    }

    .section-heading {
      font-size: 1.5rem;
    }

    .prose p {
      font-size: 0.95rem;
    }

    .image-pair {
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.75rem;
    }

    .group-description {
      font-size: 0.95rem;
    }

    .research-questions-box {
      gap: 1.5rem;
    }

    .question-badge {
      min-width: 55px;
      width: 55px;
      height: 55px;
    }

    .question-number {
      font-size: 1.6rem;
    }

    .question-content p {
      font-size: 0.95rem;
    }

    .emoji-icon {
      font-size: 1.2rem;
    }
  }

  /* Tablet (768px and below) */
  @media (max-width: 768px) {
    .content-section {
      padding: 3rem 1.25rem 2.5rem;
    }

    .section-container {
      padding: 0 1.25rem;
    }

    .section-heading {
      font-size: 1.35rem;
      margin-bottom: 1.25rem;
      padding-bottom: 0.5rem;
    }

    .section-heading::after {
      width: 40px;
    }

    .prose p {
      font-size: 0.95rem;
      line-height: 1.7;
      margin-bottom: 1rem;
    }

    .problem-highlights {
      margin: 1.5rem 0 1.25rem 0;
    }

    .problem-highlights > p {
      font-size: 0.95rem;
      margin-bottom: 1rem;
    }

    .highlight-box {
      gap: 1rem;
    }

    .highlight-item {
      padding: 1rem;
      border-left-width: 3px;
    }

    .highlight-number {
      width: 36px;
      height: 36px;
      font-size: 1rem;
    }

    .emoji-icon {
      font-size: 1rem;
    }

    .highlight-content h4 {
      font-size: 1rem;
    }

    .highlight-content p {
      font-size: 0.9rem;
    }

    .conclusion {
      padding: 1rem;
      font-size: 0.95rem;
    }

    .image-groups {
      gap: 2rem;
    }

    .image-group {
      padding-bottom: 2rem;
    }

    .image-pair {
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
    }

    .image-card {
      border-radius: 14px;
    }

    .group-description {
      font-size: 0.9rem;
      margin-bottom: 1.25rem;
    }

    .research-questions-box {
      grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
      gap: 1.25rem;
      margin: 2rem 0 0 0;
    }

    .question-item {
      padding: 1.5rem;
      gap: 1.25rem;
    }

    .question-badge {
      min-width: 50px;
      width: 50px;
      height: 50px;
    }

    .question-number {
      font-size: 1.5rem;
    }

    .question-content p {
      font-size: 0.9rem;
      line-height: 1.65;
    }
  }

  /* Mobile (480px and below) */
  @media (max-width: 480px) {
    .content-section {
      padding: 2.5rem 1rem 2rem;
    }

    .section-container {
      padding: 0 1rem;
    }

    .section-heading {
      font-size: 1.2rem;
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
    }

    .section-heading::after {
      width: 35px;
    }

    .prose p {
      font-size: 0.9rem;
      line-height: 1.65;
      margin-bottom: 0.9rem;
    }

    .problem-highlights {
      margin: 1.25rem 0 1rem 0;
    }

    .problem-highlights > p {
      font-size: 0.9rem;
      margin-bottom: 1rem;
    }

    .highlight-box {
      grid-template-columns: 1fr;
      gap: 0.85rem;
    }

    .highlight-item {
      padding: 0.9rem;
      gap: 0.8rem;
      border-left-width: 3px;
    }

    .highlight-number {
      width: 32px;
      height: 32px;
      font-size: 0.9rem;
    }

    .emoji-icon {
      font-size: 0.9rem;
    }

    .highlight-content h4 {
      font-size: 0.95rem;
      margin-bottom: 0.4rem;
    }

    .highlight-content p {
      font-size: 0.85rem;
      line-height: 1.5;
    }

    .conclusion {
      padding: 0.9rem;
      font-size: 0.9rem;
      border-left-width: 3px;
    }

    .image-groups {
      gap: 1.5rem;
      margin-top: 1.25rem;
    }

    .image-group {
      padding-bottom: 1.5rem;
    }

    .image-pair {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .image-card {
      border-radius: 12px;
      aspect-ratio: 16 / 9;
    }

    .group-description {
      font-size: 0.85rem;
      margin-bottom: 1rem;
    }

    .research-questions-box {
      grid-template-columns: 1fr;
      gap: 1rem;
      margin: 1.75rem 0 0 0;
    }

    .question-item {
      padding: 1.25rem;
      gap: 1rem;
    }

    .question-badge {
      min-width: 48px;
      width: 48px;
      height: 48px;
      box-shadow: 0 2px 8px rgba(192, 94, 60, 0.25);
    }

    .question-number {
      font-size: 1.4rem;
    }

    .question-content p {
      font-size: 0.85rem;
      line-height: 1.6;
    }
  }

  /* Extra Small (360px and below) */
  @media (max-width: 360px) {
    .content-section {
      padding: 2rem 0.75rem 1.5rem;
    }

    .section-container {
      padding: 0 0.75rem;
    }

    .section-heading {
      font-size: 1.1rem;
    }

    .prose p {
      font-size: 0.85rem;
      line-height: 1.6;
      margin-bottom: 0.75rem;
    }

    .highlight-item {
      padding: 0.8rem;
      gap: 0.6rem;
    }

    .highlight-number {
      width: 30px;
      height: 30px;
      font-size: 0.85rem;
    }

    .emoji-icon {
      font-size: 0.8rem;
    }

    .highlight-content h4 {
      font-size: 0.9rem;
    }

    .highlight-content p {
      font-size: 0.8rem;
      line-height: 1.5;
    }

    .conclusion {
      padding: 0.8rem;
      font-size: 0.85rem;
    }

    .image-card {
      border-radius: 10px;
    }

    .image-pair {
      gap: 1rem;
    }

    .group-description {
      font-size: 0.8rem;
    }

    .research-questions-box {
      gap: 0.75rem;
    }

    .question-item {
      padding: 1rem;
      gap: 0.8rem;
    }

    .question-badge {
      min-width: 45px;
      width: 45px;
      height: 45px;
    }

    .question-number {
      font-size: 1.25rem;
    }

    .question-content p {
      font-size: 0.8rem;
    }
  }

  /* Extra Small (320px and below) */
  @media (max-width: 320px) {
    .content-section {
      padding: 1.75rem 0.5rem 1.5rem;
    }

    .section-container {
      padding: 0 0.5rem;
    }

    .section-heading {
      font-size: 1.05rem;
      letter-spacing: -0.01em;
    }

    .prose p {
      font-size: 0.8rem;
      line-height: 1.55;
    }

    .image-card {
      border-radius: 8px;
    }

    .question-item {
      padding: 0.9rem;
      gap: 0.75rem;
    }

    .question-badge {
      min-width: 42px;
      width: 42px;
      height: 42px;
    }

    .question-number {
      font-size: 1.2rem;
    }

    .question-content p {
      font-size: 0.75rem;
    }
  }

  .reveal {
    opacity: 1 !important;
    transform: none !important;
  }
</style>
