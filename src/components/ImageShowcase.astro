---
// ImageShowcase.astro — Section 3: Image/Video comparison groups

const imageGroups = [
  {
    description: "Critical example of failure and near miss due to vibration.",
    images: [
      { 
        src: "https://drive.google.com/file/d/1niyuelhmT75kiylbe4b-OKTOX10nwyKl/preview", 
        alt: "Conventional storage video", 
        caption: "Real-time Capture",
        isVideo: true 
      }, 
      { 
        src: "https://drive.google.com/thumbnail?id=1cCOkD-07gkVU_4yxMg31fcoXqf5gX9MT&sz=w1000", 
        alt: "Adaptive storage", 
        caption: "Vibration Analysis",
        isVideo: false 
      },
    ],
  },
  {
    description: "Existing system fails to deal with vibration",
    images: [
      { 
        src: "https://drive.google.com/file/d/1d0NzHbr9tLY3J6kul0ASwKZL9BZiMAeu/preview", 
        alt: "Conventional storage video", 
        caption: "Without Adaptation",
        isVideo: true 
      }, 
      { 
        src: "https://drive.google.com/thumbnail?id=16Yvv_30e39Ls8XdcL4X_U8xKTXmARlnF&sz=w1000", 
        alt: "Adaptive storage", 
        caption: "VibraBox Corrected",
        isVideo: false 
      },
    ],
  },
];
---

<section id="image-showcase" class="content-section">
  <div class="section-container">
    <h2 class="section-heading reveal">Problem Statement</h2>

    <div class="image-groups">
      {imageGroups.map((group, index) => (
        <div class="image-group reveal" style={`transition-delay: ${index * 0.1}s`}>
          <p class="group-description">{group.description}</p>
          <div class="image-pair">
            {group.images.map((media) => (
              <div class="image-card-wrapper">
                <div class="image-card card">
                  {media.isVideo ? (
                    <iframe 
                      src={media.src} 
                      width="100%" 
                      height="260" 
                      allow="autoplay" 
                      style="border:none;"
                      title={media.alt}
                      loading="lazy">
                    </iframe>
                  ) : (
                    <img src={media.src} alt={media.alt} loading="lazy" />
                  )}
                </div>
                <p class="image-caption">{media.caption}</p>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>


<section id="abstract" class="content-section">
  <div class="section-container">
    <h2 class="section-heading reveal">Research Questions</h2>

    <div class="prose reveal">
      <p>
        We propose <strong>VibraBox</strong>, a vibration-aware robot Black Box that enables efficient yet perception-faithful 
        recording under real-world disturbances. It is guided by three system-level research questions:
      </p>

      <p>
        (<strong>i</strong>) <strong>RQ<sub>1</sub>:</strong> 
        How to <em>record</em> continuously within bounded resources while preserving pre/during/post-event context;
      </p>

      <p>
        (<strong>ii</strong>) <strong>RQ<sub>2</sub>:</strong> 
        How to <em>remove</em> temporal and spatial redundancy without sacrificing downstream replay fidelity for 
        downstream perception and localization; this directly targets failure modes that cause robustness to collapse in real deployments.
      </p>

      <p>
        (<strong>iii</strong>) <strong>RQ<sub>3</sub>:</strong> 
        How to <em>adapt</em> to vibration-induced corruption so replay remains consistent with online behavior.
      </p>
    </div>
  </div>
</section>

<style>
  /* ========== SECTION CONTAINER ========== */

  .content-section {
    padding: 4rem 0.5rem 3rem;
    width: 100%;
    box-sizing: border-box;
  }

  .section-container {
    max-width: 100%;
    margin: 0 auto;
    width: 100%;
    padding: 0 1rem;
    box-sizing: border-box;
  }

  /* ========== HEADING STYLES ========== */

  .section-heading {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 400;
    color: var(--color-primary);
    margin: 0 0 1.5rem 0;
    position: relative;
    padding-bottom: 0.75rem;
    word-break: break-word;
    letter-spacing: -0.015em;
    line-height: 1.2;
  }

  .section-heading::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 48px;
    height: 3px;
    background: var(--color-accent);
    border-radius: 2px;
  }

  /* ========== IMAGE GROUPS ========== */

  .image-groups {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .image-group {
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border-light);
  }

  .image-group:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .group-description {
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.7;
    color: var(--color-primary);
    margin: 0 0 1.5rem 0;
    max-width: 100%;
  }

  .image-pair {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  /* ========== IMAGE CARD WITH CAPTION ========== */

  .image-card-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .image-card {
    border-radius: 14px;
    overflow: hidden;
    background: #f5f5f5;
    height: 260px;
    position: relative;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
    border: 1px solid var(--color-border-light);
  }

  .image-card:hover {
    box-shadow: 0 12px 32px rgba(27, 42, 74, 0.15);
    transform: translateY(-4px);
    border-color: var(--color-accent);
  }

  .image-card img, 
  .image-card iframe {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .image-card:hover img,
  .image-card:hover iframe {
    transform: scale(1.05);
  }

  /* ========== IMAGE CAPTION ========== */

  .image-caption {
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.5;
    color: var(--color-text-muted);
    margin: 0;
    padding: 0 0.25rem;
    text-align: center;
    letter-spacing: 0.3px;
    text-transform: uppercase;
  }

  /* ========== PROSE SECTION ========== */

  .prose {
    max-width: 100%;
  }

  .prose p {
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text);
    margin-bottom: 1.25rem;
    word-break: break-word;
  }

  .prose p:last-child {
    margin-bottom: 0;
  }

  .prose strong {
    color: var(--color-accent);
    font-weight: 600;
  }

  .prose em {
    color: var(--color-primary);
    font-style: italic;
  }

  .reveal {
    opacity: 1 !important;
    transform: none !important;
  }

  /* ========== RESPONSIVE STYLES ========== */

  /* Tablet (1024px and below) */
  @media (max-width: 1024px) {
    .content-section {
      padding: 3.5rem 0.4rem 3rem;
    }

    .section-heading {
      font-size: 1.5rem;
    }

    .image-card {
      height: 240px;
    }

    .image-pair {
      gap: 1.25rem;
    }

    .image-caption {
      font-size: 0.85rem;
    }
  }

  /* Tablet (768px and below) */
  @media (max-width: 768px) {
    .content-section {
      padding: 3rem 0.35rem 2.5rem;
    }

    .section-container {
      padding: 0 0.75rem;
    }

    .section-heading {
      font-size: 1.35rem;
      margin-bottom: 1.25rem;
      padding-bottom: 0.5rem;
    }

    .section-heading::after {
      width: 40px;
    }

    .image-groups {
      gap: 1.75rem;
    }

    .image-group {
      padding-bottom: 1.75rem;
    }

    .group-description {
      font-size: 0.95rem;
      margin-bottom: 1.25rem;
    }

    .image-pair {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.15rem;
    }

    .image-card {
      height: 220px;
      border-radius: 12px;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    }

    .image-card-wrapper {
      gap: 0.65rem;
    }

    .image-caption {
      font-size: 0.8rem;
    }

    .prose p {
      font-size: 0.95rem;
      margin-bottom: 1rem;
    }
  }

  /* Mobile (480px and below) */
  @media (max-width: 480px) {
    .content-section {
      padding: 2.5rem 0.3rem 2rem;
    }

    .section-container {
      padding: 0 0.5rem;
    }

    .section-heading {
      font-size: 1.2rem;
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
    }

    .section-heading::after {
      width: 35px;
    }

    .image-groups {
      gap: 1.5rem;
    }

    .image-group {
      padding-bottom: 1.5rem;
    }

    .group-description {
      font-size: 0.9rem;
      margin-bottom: 1rem;
    }

    .image-pair {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .image-card {
      height: 200px;
      border-radius: 11px;
    }

    .image-card-wrapper {
      gap: 0.6rem;
    }

    .image-caption {
      font-size: 0.75rem;
      letter-spacing: 0.2px;
    }

    .prose p {
      font-size: 0.9rem;
      line-height: 1.7;
      margin-bottom: 0.9rem;
    }
  }

  /* Extra Small (360px and below) */
  @media (max-width: 360px) {
    .content-section {
      padding: 2rem 0.25rem 1.5rem;
    }

    .section-container {
      padding: 0 0.4rem;
    }

    .section-heading {
      font-size: 1.1rem;
    }

    .group-description {
      font-size: 0.85rem;
    }

    .image-card {
      height: 180px;
      border-radius: 10px;
    }

    .image-caption {
      font-size: 0.7rem;
    }

    .prose p {
      font-size: 0.85rem;
      line-height: 1.65;
    }
  }

  /* Extra Small (320px and below) */
  @media (max-width: 320px) {
    .content-section {
      padding: 1.75rem 0.2rem 1.5rem;
    }

    .section-container {
      padding: 0 0.35rem;
    }

    .section-heading {
      font-size: 1.05rem;
      letter-spacing: -0.01em;
    }

    .group-description {
      font-size: 0.8rem;
    }

    .image-card {
      height: 160px;
      border-radius: 8px;
    }

    .image-caption {
      font-size: 0.65rem;
    }

    .prose p {
      font-size: 0.8rem;
      line-height: 1.55;
    }
  }
</style>