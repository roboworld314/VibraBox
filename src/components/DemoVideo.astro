---
// DemoVideo.astro — Section 5: Demo video
---
<section id="demo-video" class="content-section">
  <div class="section-container">
    <div class="header-with-actions">
      <div class="header-content">
        <h2 class="section-heading reveal">Demo Video</h2>
        
      </div>
      <a 
        href="https://drive.google.com/file/d/1KzPWLz3nezkVdFmeEmsCXbyc-ZKv6xac/view?usp=sharing" 
        target="_blank" 
        class="external-link-icon"
        title="Open in external window"
        rel="noopener noreferrer"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
          <polyline points="15 3 21 3 21 9"></polyline>
          <line x1="10" y1="14" x2="21" y2="3"></line>
        </svg>
      </a>
    </div>

    <!-- Video Caption -->
    <div class="video-caption reveal">
      <p>
        <strong>VibraBox</strong> is a vibration-aware black-box system for mobile robots that ensures reliable replay of critical events. It combines always-on bounded buffering with event-triggered persistence to capture essential pre-, during-, and post-event context under strict onboard constraints. A fidelity-aware data pipeline and adaptive control policy reduce redundancy while preserving perception consistency, enabling efficient, real-time, and trustworthy failure reconstruction.
      </p>
    </div>

    <!-- Video Block -->
    <div class="video-block card reveal">
      <div class="video-container" id="videoWrapper">
        <iframe
          id="videoIframe"
          src="https://drive.google.com/file/d/1KzPWLz3nezkVdFmeEmsCXbyc-ZKv6xac/preview"
          allow="autoplay; fullscreen"
          frameborder="0"
          loading="lazy"
          title="VibraBox Demo Video"
        ></iframe>
        
        <div class="zoom-controls">
          <button onclick="changeZoom(-0.1)" title="Zoom Out" aria-label="Zoom Out">−</button>
          <span id="zoomLevel">100%</span>
          <button onclick="changeZoom(0.1)" title="Zoom In" aria-label="Zoom In">+</button>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  let currentZoom = 1;
  function changeZoom(delta) {
    const iframe = document.getElementById('videoIframe');
    const zoomText = document.getElementById('zoomLevel');
    currentZoom = Math.max(0.5, Math.min(2, currentZoom + delta));
    iframe.style.transform = `scale(${currentZoom})`;
    zoomText.innerText = `${Math.round(currentZoom * 100)}%`;
  }
</script>

<style>
  /* ========== SECTION CONTAINER (MATCHES HERO.ASTRO) ========== */

  .content-section {
    padding: 4rem 3rem 3rem;
    width: 100%;
    box-sizing: border-box;
  }

  .section-container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    padding: 0 3rem;
    box-sizing: border-box;
  }

  /* ========== HEADER STYLES ========== */

  .header-with-actions {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 2rem;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .header-content {
    flex: 1;
    min-width: 0;
  }

  .section-heading {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 400;
    color: var(--color-primary);
    margin: 0 0 0.5rem 0;
    position: relative;
    padding-bottom: 0.75rem;
    word-break: break-word;
    letter-spacing: -0.015em;
    line-height: 1.2;
  }

  .section-heading::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 48px;
    height: 3px;
    background: var(--color-accent);
    border-radius: 2px;
  }

  .section-subtitle {
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text-muted);
    margin: 0;
    max-width: 100%;
  }

  .external-link-icon {
    color: var(--color-primary);
    padding: 12px;
    border-radius: 12px;
    transition: all 0.3s ease;
    background: linear-gradient(135deg, rgba(192, 94, 60, 0.08) 0%, rgba(27, 42, 74, 0.03) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    border: 1px solid rgba(192, 94, 60, 0.2);
    cursor: pointer;
  }

  .external-link-icon:hover {
    background: linear-gradient(135deg, rgba(192, 94, 60, 0.15) 0%, rgba(27, 42, 74, 0.08) 100%);
    border-color: var(--color-accent);
    transform: translateY(-3px);
    box-shadow: 0 4px 12px rgba(192, 94, 60, 0.15);
  }

  /* ========== VIDEO CAPTION STYLES ========== */

  .video-caption {
    background: linear-gradient(135deg, rgba(192, 94, 60, 0.05) 0%, rgba(27, 42, 74, 0.03) 100%);
    border-left: 4px solid var(--color-accent);
    border: 1px solid rgba(192, 94, 60, 0.1);
    padding: 1.75rem;
    border-radius: 14px;
    margin-bottom: 2rem;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.05);
    transition: all 0.3s ease;
  }

  .video-caption:hover {
    border-color: rgba(192, 94, 60, 0.2);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.08);
  }

  .video-caption p {
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text);
    margin: 0;
    word-break: break-word;
  }

  .video-caption strong {
    color: var(--color-accent);
    font-weight: 600;
  }

  /* ========== VIDEO BLOCK STYLES ========== */

  .video-block {
    border-radius: 18px;
    overflow: hidden;
    position: relative;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .video-block:hover {
    box-shadow: 0 16px 48px rgba(27, 42, 74, 0.2);
    transform: translateY(-4px);
  }

  .video-container {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #0f0f14;
    position: relative;
    overflow: hidden;
  }

  #videoIframe {
    width: 100%;
    height: 100%;
    transition: transform 0.2s ease-out;
    transform-origin: center;
    display: block;
  }

  .zoom-controls {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(30, 30, 30, 0.92);
    color: white;
    padding: 10px 20px;
    border-radius: 28px;
    display: flex;
    align-items: center;
    gap: 18px;
    backdrop-filter: blur(12px);
    z-index: 10;
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
    transition: all 0.3s ease;
  }

  .zoom-controls:hover {
    background: rgba(40, 40, 40, 0.95);
    border-color: rgba(255, 255, 255, 0.18);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.5);
  }

  .zoom-controls button {
    background: none;
    border: none;
    color: white;
    font-size: 1.6rem;
    cursor: pointer;
    line-height: 1;
    padding: 0;
    transition: all 0.2s;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .zoom-controls button:hover {
    opacity: 0.8;
    transform: scale(1.1);
  }

  .zoom-controls button:active {
    transform: scale(0.95);
  }

  .zoom-controls span {
    font-family: var(--font-mono, 'Monaco', 'Courier New', monospace);
    font-size: 0.95rem;
    min-width: 48px;
    text-align: center;
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  /* ========== RESPONSIVE STYLES ========== */

  /* Tablet (1024px and below) */
  @media (max-width: 1024px) {
    .content-section {
      padding: 3.5rem 2.5rem 3rem;
    }

    .section-container {
      padding: 0 2.5rem;
    }

    .section-heading {
      font-size: 1.5rem;
    }

    .section-subtitle {
      font-size: 0.95rem;
    }

    .header-with-actions {
      margin-bottom: 1.75rem;
      gap: 1.25rem;
    }

    .video-caption {
      padding: 1.5rem;
      margin-bottom: 1.75rem;
    }

    .video-caption p {
      font-size: 0.95rem;
      line-height: 1.75;
    }
  }

  /* Tablet (768px and below) */
  @media (max-width: 768px) {
    .content-section {
      padding: 3rem 1.75rem 2.5rem;
    }

    .section-container {
      padding: 0 1.75rem;
    }

    .header-with-actions {
      flex-direction: column;
      align-items: flex-start;
      margin-bottom: 1.5rem;
      gap: 1rem;
    }

    .header-content {
      width: 100%;
    }

    .section-heading {
      font-size: 1.35rem;
      margin-bottom: 0.4rem;
      padding-bottom: 0.5rem;
    }

    .section-heading::after {
      width: 40px;
    }

    .section-subtitle {
      font-size: 0.9rem;
      line-height: 1.7;
    }

    .external-link-icon {
      padding: 10px;
      border-radius: 10px;
    }

    .video-caption {
      padding: 1.25rem;
      margin-bottom: 1.5rem;
      border-left-width: 3px;
    }

    .video-caption p {
      font-size: 0.9rem;
      line-height: 1.7;
    }

    .video-block {
      border-radius: 16px;
      box-shadow: 0 6px 24px rgba(0, 0, 0, 0.12);
    }

    .zoom-controls {
      bottom: 16px;
      padding: 8px 16px;
      gap: 14px;
      border-radius: 24px;
    }

    .zoom-controls button {
      font-size: 1.4rem;
    }

    .zoom-controls span {
      min-width: 44px;
      font-size: 0.9rem;
    }
  }

  /* Mobile (480px and below) */
  @media (max-width: 480px) {
    .content-section {
      padding: 2.5rem 1.25rem 2rem;
    }

    .section-container {
      padding: 0 1.25rem;
    }

    .header-with-actions {
      flex-direction: column;
      margin-bottom: 1.25rem;
      gap: 0.75rem;
    }

    .section-heading {
      font-size: 1.2rem;
      margin-bottom: 0.3rem;
      padding-bottom: 0.5rem;
    }

    .section-heading::after {
      width: 35px;
    }

    .section-subtitle {
      font-size: 0.85rem;
      line-height: 1.65;
    }

    .external-link-icon {
      padding: 9px;
      align-self: flex-start;
    }

    .external-link-icon:hover {
      transform: translateY(-2px);
    }

    .video-caption {
      padding: 1.1rem 1.25rem;
      margin-bottom: 1.25rem;
      border-left-width: 3px;
    }

    .video-caption p {
      font-size: 0.85rem;
      line-height: 1.65;
    }

    .video-block {
      border-radius: 14px;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
    }

    .zoom-controls {
      bottom: 12px;
      padding: 6px 12px;
      gap: 12px;
      border-radius: 20px;
      font-size: 0.9rem;
    }

    .zoom-controls button {
      font-size: 1.2rem;
    }

    .zoom-controls span {
      min-width: 38px;
      font-size: 0.8rem;
    }
  }

  /* Extra Small (360px and below) */
  @media (max-width: 360px) {
    .content-section {
      padding: 2rem 1rem 1.5rem;
    }

    .section-container {
      padding: 0 1rem;
    }

    .section-heading {
      font-size: 1.1rem;
    }

    .section-subtitle {
      font-size: 0.8rem;
      line-height: 1.6;
    }

    .video-caption {
      padding: 1rem 1.1rem;
      margin-bottom: 1.1rem;
      border-left-width: 3px;
    }

    .video-caption p {
      font-size: 0.8rem;
      line-height: 1.6;
    }

    .video-block {
      border-radius: 12px;
    }

    .zoom-controls {
      bottom: 10px;
      padding: 5px 10px;
      gap: 10px;
      border-radius: 18px;
    }

    .zoom-controls button {
      font-size: 1rem;
    }

    .zoom-controls span {
      min-width: 35px;
      font-size: 0.75rem;
    }
  }

  /* Extra Small (320px and below) */
  @media (max-width: 320px) {
    .content-section {
      padding: 1.75rem 0.75rem 1.5rem;
    }

    .section-container {
      padding: 0 0.75rem;
    }

    .section-heading {
      font-size: 1.05rem;
      letter-spacing: -0.01em;
    }

