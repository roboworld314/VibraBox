---
// DemoVideo.astro — Section 5: Demo video
---
<section id="demo-video" class="content-section">
  <div class="section-container">
    <div class="header-with-actions">
      <h2 class="section-heading reveal">Demo Video</h2>
      <a 
        href="https://drive.google.com/file/d/1KzPWLz3nezkVdFmeEmsCXbyc-ZKv6xac/view?usp=sharing" 
        target="_blank" 
        class="external-link-icon"
        title="Open in external window"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
          <polyline points="15 3 21 3 21 9"></polyline>
          <line x1="10" y1="14" x2="21" y2="3"></line>
        </svg>
      </a>
    </div>

    <!-- Video Caption -->
    <div class="video-caption reveal">
      <p>
        <strong>VibraBox</strong> is a vibration-aware black-box system for mobile robots that ensures reliable replay of critical events. It combines always-on bounded buffering with event-triggered persistence to capture essential pre-, during-, and post-event context under strict onboard constraints. A fidelity-aware data pipeline and adaptive control policy reduce redundancy while preserving perception consistency, enabling efficient, real-time, and trustworthy failure reconstruction.
      </p>
    </div>

    <!-- Video Block -->
    <div class="video-block card reveal">
      <div class="video-container" id="videoWrapper">
        <iframe
          id="videoIframe"
          src="https://drive.google.com/file/d/1KzPWLz3nezkVdFmeEmsCXbyc-ZKv6xac/preview"
          allow="autoplay; fullscreen"
          frameborder="0"
          loading="lazy"
        ></iframe>
        
        <div class="zoom-controls">
          <button onclick="changeZoom(-0.1)" title="Zoom Out">−</button>
          <span id="zoomLevel">100%</span>
          <button onclick="changeZoom(0.1)" title="Zoom In">+</button>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  let currentZoom = 1;
  function changeZoom(delta) {
    const iframe = document.getElementById('videoIframe');
    const zoomText = document.getElementById('zoomLevel');
    currentZoom = Math.max(0.5, Math.min(2, currentZoom + delta));
    iframe.style.transform = `scale(${currentZoom})`;
    zoomText.innerText = `${Math.round(currentZoom * 100)}%`;
  }
</script>

<style>
  .header-with-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .external-link-icon {
    color: var(--color-primary);
    padding: 8px;
    border-radius: 50%;
    transition: background 0.3s;
    background: rgba(0,0,0,0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .external-link-icon:hover {
    background: rgba(0,0,0,0.1);
  }

  /* Video Caption Styling */
  .video-caption {
    background: linear-gradient(135deg, rgba(192, 94, 60, 0.05) 0%, rgba(27, 42, 74, 0.03) 100%);
    border-left: 4px solid var(--color-accent);
    padding: 1.25rem 1.5rem;
    border-radius: 8px;
    margin-bottom: 1.75rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .video-caption p {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text);
    margin: 0;
    word-break: break-word;
  }

  .video-caption strong {
    color: var(--color-accent);
    font-weight: 600;
  }

  .video-block {
    border-radius: var(--radius-md);
    overflow: hidden;
    position: relative;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }

  .video-container {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #0f0f14;
    position: relative;
    overflow: hidden;
  }

  #videoIframe {
    width: 100%;
    height: 100%;
    transition: transform 0.2s ease-out;
    transform-origin: center;
  }

  .zoom-controls {
    position: absolute;
    bottom: 15px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(30, 30, 30, 0.85);
    color: white;
    padding: 5px 15px;
    border-radius: 20px;
    display: flex;
    align-items: center;
    gap: 15px;
    backdrop-filter: blur(5px);
    z-index: 10;
  }

  .zoom-controls button {
    background: none;
    border: none;
    color: white;
    font-size: 1.4rem;
    cursor: pointer;
    line-height: 1;
    padding: 0;
    transition: opacity 0.2s;
  }

  .zoom-controls button:hover {
    opacity: 0.8;
  }

  .zoom-controls span {
    font-family: sans-serif;
    font-size: 0.9rem;
    min-width: 40px;
    text-align: center;
  }

  .section-heading {
    margin-bottom: 0;
    font-family: var(--font-heading);
    font-size: 1.6rem;
    color: var(--color-primary);
    position: relative;
    padding-bottom: 0.75rem;
  }
  
  .section-heading::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 48px;
    height: 3px;
    background: var(--color-accent);
    border-radius: 2px;
  }

  /* Tablet (768px and below) */
  @media (max-width: 768px) {
    .header-with-actions {
      margin-bottom: 1.25rem;
    }

    .section-heading {
      font-size: 1.4rem;
      padding-bottom: 0.5rem;
    }

    .section-heading::after {
      width: 40px;
    }

    .video-caption {
      padding: 1rem 1.25rem;
      margin-bottom: 1.5rem;
      border-left-width: 3px;
    }

    .video-caption p {
      font-size: 0.95rem;
      line-height: 1.65;
    }

    .zoom-controls {
      padding: 4px 12px;
      gap: 12px;
    }

    .zoom-controls button {
      font-size: 1.2rem;
    }

    .zoom-controls span {
      min-width: 35px;
      font-size: 0.85rem;
    }
  }

  /* Mobile (480px and below) */
  @media (max-width: 480px) {
    .header-with-actions {
      margin-bottom: 1rem;
      flex-direction: column;
      align-items: flex-start;
    }

    .section-heading {
      font-size: 1.2rem;
      margin-bottom: 0.5rem;
    }

    .external-link-icon {
      position: static;
    }

    .video-caption {
      padding: 0.9rem 1rem;
      margin-bottom: 1.25rem;
      border-left-width: 3px;
    }

    .video-caption p {
      font-size: 0.9rem;
      line-height: 1.6;
    }

    .zoom-controls {
      bottom: 10px;
      padding: 3px 10px;
      gap: 10px;
    }

    .zoom-controls button {
      font-size: 1rem;
    }

    .zoom-controls span {
      min-width: 30px;
      font-size: 0.8rem;
    }
  }

  /* Extra Small (320px and below) */
  @media (max-width: 320px) {
    .section-heading {
      font-size: 1.1rem;
    }

    .video-caption p {
      font-size: 0.85rem;
      line-height: 1.55;
    }

    .zoom-controls {
      padding: 2px 8px;
      gap: 8px;
    }

    .zoom-controls button {
      font-size: 0.9rem;
    }

    .zoom-controls span {
      min-width: 28px;
      font-size: 0.75rem;
    }
  }
</style>