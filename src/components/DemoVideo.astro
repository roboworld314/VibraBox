      font-size: 0.75rem;em;
      line-height: 1.55;
    }

    .video-caption p {    .video-caption p {
      font-size: 0.75rem;.75rem;
      line-height: 1.55;
    }

    .video-block {
      border-radius: 10px;px;
    }

    .zoom-controls {    .zoom-controls {
      padding: 4px 8px;
      gap: 8px;
    }

    .zoom-controls button { {
      font-size: 0.9rem;m;
    }

    .zoom-controls span { .zoom-controls span {
      min-width: 32px;      min-width: 32px;
      font-size: 0.7rem;size: 0.7rem;
    }
  }

